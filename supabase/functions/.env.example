# Supabase provides SUPABASE_URL and either SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SECRET_KEYS.
# Keep this file as documentation only; never commit a real supabase/functions/.env file.

PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

APP_ALLOWED_ORIGINS=http://localhost:5173,https://your-site.netlify.app
# Optional: enables per-IP pre-auth rate-limit buckets from platform IP headers.
# Leave false unless the hosting edge is verified to overwrite/strip cf-connecting-ip,
# fly-client-ip, and x-real-ip from caller-supplied requests.
APP_TRUST_EDGE_IP_HEADERS=false

PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_BTC_USD_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
PYTH_ETH_USD_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
PYTH_SOL_USD_ID=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

SOLANA_RPC_URL=
TOKEN_MINT=
HOLDER_MIN_BALANCE=1
# Only honored when APP_ENV/DENO_ENV/ENVIRONMENT is local, dev, development, or test.
HOLDER_PLACEHOLDER=false
