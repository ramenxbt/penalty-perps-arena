{
  "name": "penalty-perps-arena",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/prebuild-check.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:backend",
    "audit:backend": "node scripts/backend-static-audit.mjs",
    "test:edge": "deno test supabase/functions/_shared/game_test.ts supabase/functions/_shared/http_test.ts supabase/functions/_shared/rateLimit_test.ts",
    "test:backend": "npm run audit:backend && npm run test:edge && supabase test db --local supabase/tests",
    "supabase:lint": "supabase db lint --local",
    "supabase:doctor": "npm run supabase:lint && npm run test:backend",
    "supabase:db:push": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy profile leaderboard open-trade close-trade",
    "supabase:deploy": "npm run supabase:doctor && npm run supabase:db:push && npm run supabase:functions:deploy"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.32.1",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.182.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "pngjs": "^7.0.0"
  }
}
