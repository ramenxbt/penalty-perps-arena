# Penalty Perps Arena - frontend environment.
#
# Copy to `.env.local` and fill in. EVERY value here ships to the browser, so it must
# be safe to expose publicly. Never put service-role keys, the Privy app secret, or
# write-capable RPC keys in this file - those belong only to the backend (see
# BACKEND_HANDOFF.md).
#
# The app runs fully in LOCAL paper mode with none of these set. It switches to
# CONNECTED (server-authoritative) mode automatically once the Supabase vars are present.

# --- Auth (Privy) ---------------------------------------------------------
# Public app id from the Privy dashboard. Enables real wallet / email / X login.
# Leave unset to run in guest mode.
VITE_PRIVY_APP_ID=

# --- Backend (Supabase) ---------------------------------------------------
# Project URL and anon (publishable) key. The anon key is safe client-side because
# Row Level Security, not key secrecy, protects the data. Set BOTH to enable
# connected mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Set to true in hosted connected deployments so missing auth/backend config fails loudly
# instead of falling back to browser-only local scoring.
VITE_REQUIRE_BACKEND=false

# --- Market data (Pyth) ---------------------------------------------------
# Optional overrides. Defaults to the public Hermes mainnet endpoint and the
# canonical BTC/USD, ETH/USD, and SOL/USD price-feed ids.
VITE_PYTH_HERMES_URL=https://hermes.pyth.network
VITE_PYTH_BTC_USD_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
VITE_PYTH_ETH_USD_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
VITE_PYTH_SOL_USD_ID=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

# --- Token (optional, placeholder until a mint exists) --------------------
# When set, the holder badge and reward-eligibility gate become meaningful.
# The actual holder check runs SERVER-side; this is only for display.
VITE_TOKEN_MINT=
VITE_TOKEN_SYMBOL=PERP
